# --- 系统 & IDE ---
.DS_Store
Thumbs.db
.vscode/
.idea/
*.log

# --- Node.js (前后端通用) ---
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.npm
package-lock.json
# 如果使用 yarn/pnpm，通常保留其 lock 文件，但忽略其缓存
.pnpm-store/

# --- 环境变量 & 密钥 (极其重要) ---
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.pem
# Cloudflare 特有的密钥文件
.dev.vars

# --- 编译 & 构建产物 ---
dist/
build/
.next/
.out/
# 如果是 Cloudflare Pages/Workers 的本地产物
.cloudflare/

# --- Cloudflare Wrangler / D1 状态 ---
# 忽略本地模拟器的状态，包括本地 D1 数据库文件
.wrangler/
# 排除 wrangler 产生的临时文件
wrangler.toml.bak

# --- 数据库文件 (SQLite / Local DB) ---
*.db
*.sqlite
*.sqlite-journal

# --- 测试 ---
coverage/
.nyc_output/
# OpenNext
.open-next
